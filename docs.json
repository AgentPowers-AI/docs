{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "AgentPowers",
  "colors": {
    "primary": "#6D28D9",
    "light": "#8B5CF6",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/buying-skills",
              "guides/selling-skills",
              "guides/cli-usage",
              "guides/plugin-usage",
              "guides/security-pipeline"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/AgentPowers-AI",
          "icon": "github"
        },
        {
          "anchor": "Website",
          "href": "https://agentpowers.ai",
          "icon": "globe"
        }
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/AgentPowers-AI",
      "x": "https://x.com/agentpowers"
    }
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript"]
    }
  },
  "seo": {
    "indexing": "navigable"
  }
}
