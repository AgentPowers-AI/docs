{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AgentPowers",
  "colors": {
    "primary": "#38BDB8",
    "light": "#4DCDC8",
    "dark": "#2A9D98"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "dark": "/logo/logo_agentpowers.svg",
    "light": "/logo/logo_agentpowers-light.svg"
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk",
      "weight": 700
    },
    "body": {
      "family": "DM Sans"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/buying-skills",
              "guides/selling-skills",
              "guides/agents-vs-skills",
              "guides/cli-usage",
              "guides/plugin-usage",
              "guides/codex-plugin",
              "guides/claude-extension",
              "guides/mcp-server",
              "guides/security-pipeline",
              "guides/external-skills"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "guides/account-deletion",
              "guides/error-codes",
              "guides/rate-limits",
              "guides/roadmap"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/AgentPowers-AI",
          "icon": "github"
        },
        {
          "anchor": "Website",
          "href": "https://agentpowers.ai",
          "icon": "globe"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/ECAzvrvHA",
          "icon": "discord"
        }
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/AgentPowers-AI",
      "x": "https://x.com/agentpowersAI",
      "discord": "https://discord.gg/ECAzvrvHA"
    }
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript"]
    }
  },
  "seo": {
    "indexing": "navigable"
  },
  "background": {
    "color": {
      "dark": "#0C0C0E",
      "light": "#FAFAF9"
    }
  },
  "description": "Documentation for AgentPowers",
  "appearance": {
    "default": "dark"
  }
}
